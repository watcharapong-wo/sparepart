{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run sparepart server",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "start"
      ],
      "isBackground": true,
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "never",
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": false
      },
      "problemMatcher": [
        {
          "owner": "custom",
          "pattern": {
            "regexp": ".*"
          },
          "background": {
            "activeOnStart": true,
            "beginsPattern": "🚀 SERVER IS LIVE WITH FULL APIS!",
            "endsPattern": "🔗 URL: http://localhost:5000"
          }
        }
      ]
    }
  ]
}