DB_CLIENT=sqlite
DB_FALLBACK_TO_SQLITE=true
SQLITE_DB_PATH=./sparepart.db

# SQL Server settings
MSSQL_SERVER=localhost
MSSQL_INSTANCE_NAME=SQLEXPRESS
MSSQL_PORT=1433
MSSQL_DATABASE=sparepart
MSSQL_USER=sa
MSSQL_PASSWORD=your_password_here
MSSQL_ENCRYPT=false
MSSQL_TRUST_SERVER_CERTIFICATE=true
MSSQL_POOL_MAX=10
MSSQL_POOL_MIN=0
MSSQL_POOL_IDLE_TIMEOUT_MS=30000
